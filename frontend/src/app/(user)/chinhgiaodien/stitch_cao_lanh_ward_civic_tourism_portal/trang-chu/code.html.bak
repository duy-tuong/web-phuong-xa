<div class="opacity-0 group-hover:opacity-100 transition-all duration-500 delay-200 transform translate-y-4 group-hover:translate-y-0">
<span class="inline-flex items-center gap-2 bg-[#0f7a5a] text-white text-sm font-bold px-4 py-2 rounded-full hover:bg-white hover:text-[#0f7a5a] transition-colors">Xem chi tiết <span class="material-symbols-outlined text-sm">arrow_forward</span></span>
