<div class="w-px h-4 bg-slate-300"></div>
<div class="flex items-center gap-2">
<a class="text-primary font-bold" href="#">VN</a>
<span class="text-slate-300">|</span>
<a class="hover:text-primary transition-colors" href="#">EN</a>
</div>
<div class="w-px h-4 bg-slate-300"></div>
<a class="flex items-center gap-1 bg-primary text-white px-3 py-1.5 rounded-md hover:bg-primary/90 transition-colors shadow-sm" href="#">
<span class="material-symbols-outlined text-[18px]">login</span> Đăng nhập
    </a>
</div>
<div class="relative w-full flex justify-end">
<span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm">search</span>
