            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#1f7a5a",
                        "secondary": "#db2777",
                        "background-light": "#f8fafc",
                        "background-dark": "#0f231d",
                        "footer": "#f3f4f6"
                    },
                    fontFamily: {
                        "display": ["Public Sans", "sans-serif"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "1rem",
                        "full": "9999px"
                    },
                },
            },
        }
