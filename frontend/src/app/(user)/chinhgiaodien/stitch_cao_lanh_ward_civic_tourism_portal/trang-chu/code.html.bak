<style type="text/tailwindcss">
        .glass-panel {
            @apply bg-white/80 dark:bg-slate-900/80 backdrop-blur-md border border-slate-200/50 dark:border-slate-700/50;
        }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100 antialiased overflow-x-hidden">
<header class="w-full z-50 bg-[#f3f4f6]">
<div class="relative overflow-hidden border-b border-primary/20">
