<div class="hidden lg:flex items-center gap-2 text-white text-sm font-medium bg-black/10 px-4 py-2 rounded-[4px] whitespace-nowrap">
<span class="material-symbols-outlined text-[20px] text-yellow-300">partly_cloudy_day</span>
<span>Cao Lãnh 25–32°C</span>
</div>
</div>
</div>
