        const links = document.querySelectorAll('.lg\\:col-span-1 .p-4 a');
        if(links.length > 0) {
            links[0].addEventListener('click', (e) => {
                e.preventDefault();
                const modal = document.getElementById('modal-tracking');
                modal.classList.remove('hidden');
                modal.classList.add('flex');
            });
            links[1].addEventListener('click', (e) => {
                e.preventDefault();
                const modal = document.getElementById('modal-forms');
                modal.classList.remove('hidden');
                modal.classList.add('flex');
            });
        }
    });
</script>
</body></html>
